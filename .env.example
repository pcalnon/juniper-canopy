# =============================================================================
# juniper-canopy Environment Variables
# Copy this file to .env and customize as needed.
# Prefix: JUNIPER_CANOPY_*
# Nested settings use double-underscore: JUNIPER_CANOPY_SERVER__HOST=0.0.0.0
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────
JUNIPER_CANOPY_SERVER__HOST=127.0.0.1
JUNIPER_CANOPY_SERVER__PORT=8050
# JUNIPER_CANOPY_SERVER__DEBUG=false

# ── Logging ───────────────────────────────────────────────────────────
JUNIPER_CANOPY_LOG_LEVEL=INFO
# JUNIPER_CANOPY_LOG_FORMAT=text
# JUNIPER_CANOPY_SENTRY_DSN=

# ── Backend ───────────────────────────────────────────────────────────
JUNIPER_CANOPY_JUNIPER_DATA_URL=http://localhost:8100
# JUNIPER_CANOPY_CASCOR_SERVICE_URL=http://localhost:8200
# JUNIPER_CANOPY_DEMO_MODE=false
# JUNIPER_CANOPY_BACKEND_PATH=../juniper-cascor

# ── Demo Mode ─────────────────────────────────────────────────────────
# JUNIPER_CANOPY_DEMO_UPDATE_INTERVAL=1.0
# JUNIPER_CANOPY_DEMO_CASCADE_EVERY=30

# ── Training Parameters (nested) ─────────────────────────────────────
# JUNIPER_CANOPY_TRAINING__EPOCHS__DEFAULT=500
# JUNIPER_CANOPY_TRAINING__LEARNING_RATE__DEFAULT=0.01
# JUNIPER_CANOPY_TRAINING__HIDDEN_UNITS__DEFAULT=40

# ── WebSocket ─────────────────────────────────────────────────────────
# JUNIPER_CANOPY_WEBSOCKET__MAX_CONNECTIONS=50
# JUNIPER_CANOPY_WEBSOCKET__HEARTBEAT_INTERVAL=30

# ── Metrics & Rate Limiting ──────────────────────────────────────────
# JUNIPER_CANOPY_METRICS_ENABLED=false
# JUNIPER_CANOPY_RATE_LIMIT_ENABLED=false
# JUNIPER_CANOPY_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── Legacy (deprecated — use JUNIPER_CANOPY_* instead) ───────────────
# CASCOR_DEMO_MODE=1
# CASCOR_SERVICE_URL=http://localhost:8200
# CASCOR_LOG_LEVEL=INFO
